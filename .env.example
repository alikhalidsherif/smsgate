# Core gateway settings
APP_HOST=0.0.0.0
APP_PORT=5000
TZ=Africa/Addis_Ababa
ADMIN_KEY=change-me-admin-key
DB_PATH=/data/sms.db

# Huawei modem access
ROUTER_URL=http://192.168.8.1
ROUTER_USER=admin
ROUTER_PASS=change-me-router-password

# Optional webhook target for incoming SMS and delivery reports
WEBHOOK_URL=

# Runtime behavior
POLL_INTERVAL=10
CLEANUP_INTERVAL=21600
MODEM_MAX_THRESHOLD=400
MODEM_MESSAGE_MAX_AGE=3

# Modem connectivity hardening
MODEM_CONNECT_TIMEOUT=5
MODEM_READ_TIMEOUT=15
MODEM_CONNECT_RETRIES=3
MODEM_RETRY_BACKOFF=1.0
MODEM_FORCE_CONNECTION_CLOSE=1
POLL_BACKOFF_MAX=60
POLL_ERROR_LOG_THROTTLE=60

# SMS send outcome polling
SMS_SEND_STATUS_WAIT_SECONDS=8
SMS_SEND_STATUS_POLL_INTERVAL=1
